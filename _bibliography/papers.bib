@techreport{zanoni2024ecuador,
  title       = {Emerging Markets Bond Index Performance and Sovereign Default: The Case of Ecuador},
  author      = {Zanoni, Wladimir and Díaz, Emily and Paredes, Jorge and Andrian, Leandro Gaston and Maldonado, Juan Lorenzo},
  institution = {Inter-American Development Bank},
  year        = {2024},
  month       = mar,
  doi         = {10.18235/0005676},
  url         = {https://publications.iadb.org/en/emerging-markets-bond-index-performance-and-sovereign-default-case-ecuador},
  abstract    = {This paper delves into the dynamic impact of Ecuador's 2008 sovereign debt default on the subsequent performance of the country's bonds, specifically as measured by the Emerging Markets Bond Index (EMBI). Employing a synthetic control method, the study assesses the default's impact on Ecuador's EMBI performance, revealing a dynamically heterogeneous influence that fluctuates with evolving macroeconomic and political landscapes.},
  abbr        = {IDB},
  bibtex_show = {true}
}

@techreport{zanoni2023nudging,
  title       = {Nudging the Agents: Does it Reduce Discrimination Against Migrants in the House Rental Market?},
  author      = {Zanoni, Wladimir and Díaz, Lina M. and Díaz, Emily and Paredes, Jorge and Acevedo, Paloma},
  institution = {Inter-American Development Bank},
  year        = {2023},
  month       = oct,
  doi         = {10.18235/0005242},
  url         = {https://publications.iadb.org/en/nudging-agents-does-it-reduce-discrimination-against-migrants-house-rental-market},
  abstract    = {This study examines the impact of a behavioral intervention on reducing discrimination against Venezuelan migrants in the screening of home rental applications conducted by Ecuadorian real estate agents. Our artifactual field experiment demonstrated a meaningful increase of 33.67% in the preference for Venezuelan migrants over native applicants.},
